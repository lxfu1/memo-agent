# Model API configuration
# For OpenAI: https://api.openai.com/v1
# For OpenRouter: https://openrouter.ai/api/v1
# For company internal: http://your-company-api/v1
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_API_KEY=sk-...
MODEL_NAME=gpt-4o
